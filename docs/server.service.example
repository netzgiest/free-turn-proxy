[Unit]
Description=Free TURN Proxy Server
Documentation=https://github.com/samosvalishe/free-turn-proxy
After=network.target
Wants=network-online.target

[Service]
Type=simple

# Путь к бинарю сервера (устанавливается install.sh в /opt/free-turn-proxy/server).
# При ручной установке — скопируйте бинарь и поправьте путь.
ExecStart=/opt/free-turn-proxy/server \
    --listen 0.0.0.0:56000 \
    --connect 127.0.0.1:51820 \
    --mode udp \
    --obf-profile rtpopus3 \
    --obf-key "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef" \
    --clients-file /opt/free-turn-proxy/clients.json

# Автоматический перезапуск при падении
Restart=always
RestartSec=5

# Безопасность: сервер не требует прав root для работы (порт 56000 — непривилегированный).
# User=nobody достаточно; CapabilityBoundingSet можно ужать, но оставляем
# CAP_NET_ADMIN/CAP_NET_BIND_SERVICE если нужен порт <1024.
User=nobody
Group=nogroup
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/free-turn-proxy

# Для CLI-команд (clients add/remove/del/show) требуется root, т.к. они вызывают
# wg и читают /etc/wireguard/wg0.conf. Выполняйте их через sudo:
#   sudo /opt/free-turn-proxy/server clients add <id> "comment"
# В Docker-режиме команды выполняйте на хосте, не внутри контейнера.

[Install]
WantedBy=multi-user.target
